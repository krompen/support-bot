import sqlite3
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes
from telegram.constants import ParseMode

# ==================== КОНФИГУРАЦИЯ ====================
BOT_TOKEN = "8620646042:AAGgh2BNSKQTXG8rCr-A0iomMLO92cOQD38"  # Создай нового бота в @BotFather
ADMIN_ID = 8032626504
ADMIN_USERNAME = "@ciwige"

DB_NAME = "support.db"

# ==================== БАЗА ДАННЫХ ====================
def init_db():
    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('''CREATE TABLE IF NOT EXISTS banned (
            user_id INTEGER PRIMARY KEY
        )''')
        c.execute('''CREATE TABLE IF NOT EXISTS messages (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            username TEXT,
            text TEXT,
            replied INTEGER DEFAULT 0
        )''')
        conn.commit()

init_db()

def is_banned(user_id: int) -> bool:
    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('SELECT 1 FROM banned WHERE user_id = ?', (user_id,))
        return c.fetchone() is not None

def ban_user(user_id: int):
    with sqlite3.connect(DB_NAME) as conn:
        conn.execute('INSERT OR IGNORE INTO banned (user_id) VALUES (?)', (user_id,))
        conn.commit()

def unban_user(user_id: int):
    with sqlite3.connect(DB_NAME) as conn:
        conn.execute('DELETE FROM banned WHERE user_id = ?', (user_id,))
        conn.commit()

def save_message(user_id: int, username: str, text: str) -> int:
    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('INSERT INTO messages (user_id, username, text) VALUES (?, ?, ?)',
                 (user_id, username, text))
        conn.commit()
        return c.lastrowid

# ==================== ОБРАБОТЧИКИ ====================
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    
    if is_banned(user.id):
        await update.message.reply_text("🚫 Вы заблокированы.")
        return
    
    text = f"""<b>📋 ПРАВИЛА</b>

1. Угрозы = ЧС навсегда
2. Оскорбления = ЧС
3. Спам = ЧС
4. Попытки обмана = ЧС

━━━━━━━━━━━━━━━━
Я не покупаю ничего, не предлагать.
В случае проблем — отпишу сам.

📞 По вопросам: {ADMIN_USERNAME}

━━━━━━━━━━━━━━━━
Напишите ваш вопрос:"""
    
    await update.message.reply_text(text, parse_mode=ParseMode.HTML)

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    text = update.message.text
    
    if is_banned(user.id):
        await update.message.reply_text("🚫 Вы заблокированы.")
        return
    
    # Сохраняем сообщение
    msg_id = save_message(user.id, user.username or "нет", text)
    
    # Пересылаем админу
    await context.bot.send_message(
        ADMIN_ID,
        f"📨 <b>НОВОЕ СООБЩЕНИЕ #{msg_id}</b>\n\n"
        f"👤 @{user.username or 'нет'} (ID: {user.id})\n"
        f"💬 {text}\n\n"
        f"━━━━━━━━━━━━━━━━\n"
        f"Ответить: /answer {msg_id} текст\n"
        f"Забанить: /ban {user.id}",
        parse_mode=ParseMode.HTML
    )
    
    await update.message.reply_text(
        "✅ Сообщение отправлено. Ожидайте ответа.",
        reply_to_message_id=update.message.message_id
    )

async def answer_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    
    if len(context.args) < 2:
        await update.message.reply_text("/answer ID_сообщения текст")
        return
    
    msg_id = int(context.args[0])
    answer = " ".join(context.args[1:])
    
    with sqlite3.connect(DB_NAME) as conn:
        c = conn.cursor()
        c.execute('SELECT user_id FROM messages WHERE id = ?', (msg_id,))
        row = c.fetchone()
        
        if not row:
            await update.message.reply_text("❌ Сообщение не найдено")
            return
        
        user_id = row[0]
        c.execute('UPDATE messages SET replied = 1 WHERE id = ?', (msg_id,))
        conn.commit()
    
    try:
        await context.bot.send_message(
            user_id,
            f"📨 <b>ОТВЕТ ОТ ПОДДЕРЖКИ</b>\n\n{answer}\n\n━━━━━━━━━━━━━━━━\n{ADMIN_USERNAME}",
            parse_mode=ParseMode.HTML
        )
        await update.message.reply_text(f"✅ Ответ отправлен на сообщение #{msg_id}")
    except Exception as e:
        await update.message.reply_text(f"❌ Не удалось отправить: {e}")

async def ban_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    
    if not context.args:
        await update.message.reply_text("/ban ID")
        return
    
    user_id = int(context.args[0])
    ban_user(user_id)
    await update.message.reply_text(f"✅ {user_id} забанен")

async def unban_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    
    if not context.args:
        await update.message.reply_text("/unban ID")
        return
    
    user_id = int(context.args[0])
    unban_user(user_id)
    await update.message.reply_text(f"✅ {user_id} разбанен")

# ==================== ЗАПУСК ====================
def main():
    app = Application.builder().token(BOT_TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("answer", answer_cmd))
    app.add_handler(CommandHandler("ban", ban_cmd))
    app.add_handler(CommandHandler("unban", unban_cmd))
    
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    
    print("Бот поддержки запущен!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()